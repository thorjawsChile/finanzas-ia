# FinanzasIA — Variables de entorno
# Copia este archivo como .env en local, y configura estas variables en Vercel Dashboard

# ── Anthropic API Key ─────────────────────────────────────────────────────────
# Obtén tu key en: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Sesión (genera un string aleatorio largo) ─────────────────────────────────
# Puedes generar uno en: https://generate-secret.vercel.app/64
# O en terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=cambia_esto_por_un_string_largo_y_aleatorio_de_64_caracteres_minimo

# ── Usuarios (tú y tu pareja) ─────────────────────────────────────────────────
USER1_NAME=usuario1
USER1_PASS=contraseña_segura_1

USER2_NAME=usuario2
USER2_PASS=contraseña_segura_2

# ── CORS (tu dominio en Vercel) ───────────────────────────────────────────────
# Después de hacer deploy, reemplaza con tu URL real:
# Ejemplo: https://finanzas-ia.vercel.app
ALLOWED_ORIGIN=https://tu-app.vercel.app
